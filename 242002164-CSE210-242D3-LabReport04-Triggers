-- BEFORE UPDATE TRIGGER
DELIMITER $$

CREATE TRIGGER trg_salary_update
BEFORE UPDATE ON EMPLOYEE
FOR EACH ROW
BEGIN
    DECLARE yearsWorked INT;

    SET yearsWorked = TIMESTAMPDIFF(YEAR, OLD.StartDate, CURDATE());

    IF yearsWorked > 1 AND OLD.NoOfPub > 4 THEN
        SET NEW.IncrementRate = 20;
        SET NEW.UpdatedSalary = OLD.BasicSalary * 1.20;

    ELSEIF yearsWorked > 1 AND OLD.NoOfPub IN (2,3) THEN
        SET NEW.IncrementRate = 10;
        SET NEW.UpdatedSalary = OLD.BasicSalary * 1.10;

    ELSEIF yearsWorked > 1 AND OLD.NoOfPub = 1 THEN
        SET NEW.IncrementRate = 5;
        SET NEW.UpdatedSalary = OLD.BasicSalary * 1.05;

    ELSE
        SET NEW.IncrementRate = 0;
        SET NEW.UpdatedSalary = OLD.BasicSalary;
    END IF;
END$$

DELIMITER ;

-- AFTER UPDATE TRIGGER
DELIMITER $$

CREATE TRIGGER trg_salary_log
AFTER UPDATE ON EMPLOYEE
FOR EACH ROW
BEGIN
    IF OLD.UpdatedSalary <> NEW.UpdatedSalary OR OLD.UpdatedSalary IS NULL THEN
        INSERT INTO SALARY_LOG(EmpID, OldSalary, NewSalary, Note)
        VALUES(
            NEW.EmpID,
            OLD.UpdatedSalary,
            NEW.UpdatedSalary,
            'Salary Updated Automatically'
        );
    END IF;
END$$

DELIMITER ;

